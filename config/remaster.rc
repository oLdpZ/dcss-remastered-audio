# === DCSS Remastered Audio ===
sounds_on = true
sound_file_path = remaster/audio/sfx/
# --- eventi istantanei (SFX) ---
sound += You hit:evt__melee_hit.wav
sound += You bite:evt__melee_hit.wav
sound += You claw:evt__melee_hit.wav
sound += You shoot:evt__ranged.wav
sound += You throw:evt__ranged.wav
sound += You cast:evt__cast_spell.wav
# --- combattimento difensivo: quello che SUBISCI (nemico -> giocatore) ---
sound += bites you:evt__hurt_bite.wav
sound += claws you:evt__hurt_claw.wav
sound += hits you:evt__hurt.wav
sound += You block:evt__block.wav
sound += misses you:evt__miss_enemy.wav
sound += You drink:evt__quaff.wav
sound += You read:evt__read.wav
# --- momenti epici: PRIMA del pickup generico (DCSS gioca il primo match) ---
sound += Orb of Zot:evt__orb.wav
sound += rune of Zot:evt__rune.wav
sound += You now have:evt__pickup.wav
sound += open the door:evt__door.wav
sound += open the gate:evt__door.wav
sound += close the door:evt__door_close.wav
sound += close the gate:evt__door_close.wav
sound += climb downwards:evt__stairs_down.wav
sound += climb upwards:evt__stairs_up.wav
sound += You kill:evt__kill.wav
sound += is now dead:evt__kill.wav
sound += comes into view:evt__spot.wav
# --- level up: regex candidate (NIENTE virgole/due-punti nelle regex!), da confermare dal log ---
sound += are now a level:evt__level_up.wav
sound += experience level:evt__level_up.wav
sound += reach.*level:evt__level_up.wav
# --- HP basso: regex predefinita del motore ---
sound += LOW HITPOINT WARNING:evt__hp_low.wav
# --- morte del giocatore: sting + stop musica (il layer grafico fa il fade a nero).
#     Candidati da confermare dal log di morte reale (0.34 non ha un messaggio unico). ---
sound += You die:state__player_death.wav
sound += You have died:state__player_death.wav

# === Hook Lua: musica per zona + ducking su HP basso (Fase 3) ===
{
local last_branch = nil
local last_hp_band = nil
local last_xl = 0
local last_name = nil
function ready()
  -- Rileva una NUOVA partita (dopo la morte): nome diverso o livello esperienza azzerato.
  -- Serve perche' last_branch persiste nello stesso processo crawl.exe tra una partita e l'altra.
  local ok_n, nm = pcall(function() return you.name() end)
  local ok_x, xl = pcall(function() return you.xl() end)
  if ok_n and ok_x then
    if nm ~= last_name or xl < last_xl then
      last_branch = nil      -- forza il riavvio della musica del branch
      last_hp_band = nil
    end
    last_name = nm
    last_xl = xl
  end
  local ok, b = pcall(function() return you.branch() end)
  if ok and b and b ~= last_branch then
    last_branch = b
    crawl.playsound("remaster/audio/markers/state__branch_" .. b .. ".wav")
  end
  local hp, mhp = you.hp()
  if mhp and mhp > 0 then
    local band = ((hp * 100) / mhp) < 30 and "low" or "ok"
    if band ~= last_hp_band then
      last_hp_band = band
      crawl.playsound("remaster/audio/markers/state__hp_" .. band .. ".wav")
    end
  end
end
}
